#ifndef HEARTBEAT_H
#define HEARTBEAT_H


/**
 * @brief GPIO pin index used for heartbeat input on PORTE.
 *
 * Hardware mapping: PTE30.
 */
#define HEARTBEAT 30
#define HEARTBEAT_ADC_CHANNEL   0

/*
 * @brief Initializes the heartbeat module.
 *
 * @param priority Task priority for heartbeat processing.
 */
void Heartbeat_Init(int priority);

/*
 * @brief Starts a heartbeat measurement cycle.
 *
 * Typically called when the button is pressed.
 */
void Heartbeat_StartMeasurement(void);

/*
 * @brief ISR for ADC0 interrupt triggered by heartbeat sensor.
 * @param flags Interrupt status flags from ADC0.
 * @param hpw Pointer to higher-priority-task-woken flag used by FreeRTOS ISR APIs.
 */
void heartbeat_ADC0_IRQHandler(uint32_t adcValue, BaseType_t *hpw);

#endif
