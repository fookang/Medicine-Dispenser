#include "FreeRTOS.h"
#include "task.h"

#include "buzzer.h"
#include "button.h"
#include "servo.h"
#include "uart.h"
#include "ultrasonic.h"

/*
 * Initializes application modules that create FreeRTOS objects/tasks,
 * then starts the scheduler.
 */
void FreeRTOS_Init(void)
{
    Servo_Init();
    Button_Init();
    Buzzer_Init();
    init_uart();

    vTaskStartScheduler();
}
