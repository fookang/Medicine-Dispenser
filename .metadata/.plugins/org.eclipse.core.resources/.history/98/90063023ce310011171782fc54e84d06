#ifndef HEARTBEAT_H
#define HEARTBEAT_H

#include <stdint.h>
#include "FreeRTOS.h"
#include "task.h"

/*
 * @brief Initializes the heartbeat sensor module.
 *
 * @param priority FreeRTOS task priority for the heartbeat task.
 */
void Heartbeat_Init(UBaseType_t priority);

/*
 * @brief Returns the latest measured heart rate in BPM.
 *
 * @return Current BPM value.
 */
uint32_t Heartbeat_GetBPM(void);

/*
 * @brief Returns whether a finger/pulse is currently detected.
 *
 * @return 1 if pulse signal is valid, 0 otherwise.
 */
uint8_t Heartbeat_IsDetected(void);

#endif
