#include "ultrasonic.h"
#include "board.h"
#include "FreeRTOS.h"
#include "task.h"
#include "queue.h"
#include "semphr.h"

#include "servo.h"
#include "fsl_debug_console.h"


static volatile uint32_t us_counter = 0;
static volatile uint32_t echo_start_us = 0;
static volatile uint32_t echo_end_us = 0;

SemaphoreHandle_t ultraSem;

static void trig_pin_high(void)
{
    GPIOC->PSOR |= 1 << TRIG_PIN;
}

static void trig_pin_low(void)
{
    GPIOC->PCOR |= 1 << TRIG_PIN;
}

static void ultrasonic_task(void *arg)
{
    (void)arg;

    while (1)
    {
        echo_start_us = 0;
        echo_end_us = 0;

        trig_pin_low();

        uint32_t start = us_counter;

        // Trigger the ultrasonic sensor
        trig_pin_high();

        // Wait for 10 microseconds
        while (us_counter - start < 10)
            ;

        trig_pin_low();

        // Wait for the echo measurement to complete
        if (xSemaphoreTake(ultraSem, pdMS_TO_TICKS(100)) == pdTRUE)
        {
            // Calculate pulse width in microseconds
            uint32_t pulse_width_us = echo_end_us - echo_start_us;

            // Convert to distance in cm (speed of sound is ~34300 cm/s)
            uint32_t distance_cm = pulse_width_us * 34300 / 2000000;

            if (distance_cm < 10)
            {
                openServo();
                PRINTF("Distance: %lu cm - Servo Opened\r\n", distance_cm);
            }
            else
            {
                closeServo();
                PRINTF("Distance: %lu cm - Servo Closed\r\n", distance_cm);
            }
        }
        else
        {
            closeServo();
            PRINTF("Ultrasonic timeout\r\n");
        }
        vTaskDelay(pdMS_TO_TICKS(50));
    }
}

void Ultrasonic_PORTC_IRQHandler(uint32_t flags, BaseType_t *hpw)
{
    if (flags & 1 << ECHO_PIN)
    {
        if (GPIOC->PDIR & (1 << ECHO_PIN))
        {
            // Rising edge detected, start timer
            echo_start_us = us_counter;

            // Set interrupt to trigger on falling edge
            PORTC->PCR[ECHO_PIN] &= ~PORT_PCR_IRQC_MASK;
            PORTC->PCR[ECHO_PIN] |= PORT_PCR_IRQC(0b1010);
        }
        else
        {
            // Falling edge detected, stop timer and record time
            echo_end_us = us_counter;

            // Set interrupt back to trigger on rising edge
            PORTC->PCR[ECHO_PIN] &= ~PORT_PCR_IRQC_MASK;
            PORTC->PCR[ECHO_PIN] |= PORT_PCR_IRQC(0b1001);

            // Send pulse width to ultrasonic task
            xSemaphoreGiveFromISR(ultraSem, hpw);
        }

        // Clear interrupt flag
        PORTC->ISFR |= (1 << ECHO_PIN);
    }
}

void TPM0_Ultrasonic_IRQHandler(uint32_t flags)
{
    if (flags & TPM_STATUS_TOF_MASK)
    {
        // Clear the timer overflow flag
        TPM0->STATUS |= TPM_STATUS_TOF_MASK;

        // Increment the microsecond counter
        us_counter++;
    }
}

static void start_timer(void)
{
    TPM0->SC |= TPM_SC_CMOD(0b1);
}

static void init_timer(void)
{
    // Turn on clock gating for TPM0
    SIM->SCGC6 |= SIM_SCGC6_TPM0_MASK;

    // Set TPM0 to use MCGIRCLK (8 MHz)
    SIM->SOPT2 &= ~SIM_SOPT2_TPMSRC_MASK;
    SIM->SOPT2 |= SIM_SOPT2_TPMSRC(0b11);

    // Turn off TPM0 and clear prescaler mask
    TPM0->SC &= ~TPM_SC_CMOD_MASK;
    TPM0->SC &= ~TPM_SC_PS_MASK;

    TPM0->CNT = 0;

    // Set TPM0 prescaler
    TPM0->SC |= TPM_SC_PS(0b000); // Prescaler of 1

    // Set timer of 1us
    // 8 MHz / 1 = 8 MHz
    // 8 MHz / 1 us = 8 counts
    // Set modulo
    TPM0->MOD = 7;

    NVIC_SetPriority(TPM0_IRQn, 0);
    NVIC_EnableIRQ(TPM0_IRQn);
}

static void init_trig_pin(void)
{
    // Turn on clock gating for PORTC
    SIM->SCGC5 |= SIM_SCGC5_PORTC_MASK;

    // Set TRIG pin as GPIO
    PORTC->PCR[TRIG_PIN] &= ~PORT_PCR_MUX_MASK;
    PORTC->PCR[TRIG_PIN] |= PORT_PCR_MUX(1);

    // Set as output
    GPIOC->PDDR |= 1 << TRIG_PIN;

    // Turn off TRIG pin
    GPIOC->PCOR |= 1 << TRIG_PIN;
}

static void init_echo_pin(void)
{
    // Disable interrupts for PORTC
    NVIC_DisableIRQ(PORTC_PORTD_IRQn);

    // Turn on clock gating for PORTC
    SIM->SCGC5 |= SIM_SCGC5_PORTC_MASK;

    // Set ECHO pin as GPIO
    PORTC->PCR[ECHO_PIN] &= ~PORT_PCR_MUX_MASK;
    PORTC->PCR[ECHO_PIN] |= PORT_PCR_MUX(1);

    // Set as input
    GPIOC->PDDR &= ~(1 << ECHO_PIN);

    // Configure the interrupt for rising edge
    PORTC->PCR[ECHO_PIN] &= ~PORT_PCR_IRQC_MASK;
    PORTC->PCR[ECHO_PIN] |= PORT_PCR_IRQC(0b1001);

    // Set NVIC priority to 128
    NVIC_SetPriority(PORTC_IRQn, 128);

    // Clear any pending interrupts for PORTC
    NVIC_ClearPendingIRQ(PORTC_IRQn);
    PORTC->ISFR |= (1 << ECHO_PIN);

    // Enable the interrupt for PORTC
    NVIC_EnableIRQ(PORTC_PORTD_IRQn);
}

void ultrasonic_init(void)
{
    ultraSem = xSemaphoreCreateBinary();
    init_timer();
    start_timer();
    init_trig_pin();
    init_echo_pin();
    xTaskCreate(ultrasonic_task, "ultrasonic", configMINIMAL_STACK_SIZE + 100, NULL, 2, NULL);
}
