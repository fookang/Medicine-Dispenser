#include "FreeRTOS.h"
#include "task.h"

#include "buzzer.h"
#include "button.h"
#include "servo.h"
#include "uart.h"
#include "ultrasonic.h"

#include "fsl_debug_console.h"

/*
 * Initializes application modules that create FreeRTOS objects/tasks,
 * then starts the scheduler.
 */
void FreeRTOS_Init(void)
{
    Servo_Init();
    Button_Init();
    Buzzer_Init();
    init_uart();
    ultrasonic_init();
    PRINTF("SystemCoreClock = %lu\r\n", SystemCoreClock);
    PRINTF("configTICK_RATE_HZ = %lu\r\n", (uint32_t)configTICK_RATE_HZ);
    vTaskStartScheduler();
}
