#include "board.h"
#include "FreeRTOS.h"
#include "task.h"

#include "DHT.h"

#include "fsl_debug_console.h"

static void DHT_pin_output(void)
{
    GPIOE->PDDR |= 1 << DHT_PIN;
}

static void DHT_pin_input(void)
{
    GPIOE->PDDR &= ~(1 << DHT_PIN);
}

static void DHT_write_low(void)
{
    GPIOE->PCOR |= 1 << DHT_PIN;
}

static void DHT_write_high(void)
{
    GPIOE->PSOR |= 1 << DHT_PIN;
}

static uint32_t dht_read_pin(void)
{
	DHT_pin_input();
    GPIOE->PSOR |= 1 << DHT_PIN;
}

