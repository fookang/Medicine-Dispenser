int DHT_read(DHT_data_t *out)
{
    uint8_t bits[5] = {0};

    taskENTER_CRITICAL();

    /* Output low for 18ms start signal */
    DHT_pin_output();
    DHT_write_low();
    vTaskDelay(pdMS_TO_TICKS(18));

    /* Release line and switch to input */
    DHT_write_high();
    delay_us(30);
    DHT_pin_input();

    /* 3) wait for sensor response */
    if (!wait_for_level(0, 100)) { taskEXIT_CRITICAL(); return false; }
    if (!wait_for_level(1, 100)) { taskEXIT_CRITICAL(); return false; }
    if (!wait_for_level(0, 100)) { taskEXIT_CRITICAL(); return false; }

    /* 4) read 40 bits */
    for (int i = 0; i < 40; i++)
    {
        if (!wait_for_level(1, 70))  { taskEXIT_CRITICAL(); return false; }

        delay_us(40); /* sample in middle of bit */

        if (dht_read_pin())
            bits[i / 8] |= (1 << (7 - (i % 8)));

        if (!wait_for_level(0, 100)) { taskEXIT_CRITICAL(); return false; }
    }

    taskEXIT_CRITICAL();

    /* 5) checksum */
    if (((uint8_t)(bits[0] + bits[1] + bits[2] + bits[3])) != bits[4])
        return false;

    out->humidity_percent = bits[0];
    out->temperature_c    = bits[2];
    return true;
}


static void DHTTask(void *arg)
{
    (void)arg;

    DHT_data_t data;

    while(1)
    {
        if (DHT_read(&data))
        {
            PRINTF("Temp: %u C\r\n", data.temperature_c);
            PRINTF("Humidity: %u %%\r\n", data.humidity_percent);
        }
        else
        {
            PRINTF("DHT11 read failed\r\n");
        }

        vTaskDelay(pdMS_TO_TICKS(10000));
    }
}

void DHT_init(void)
{
    // Turn on clock gating
    SIM->SCGC5 |= SIM_SCGC5_PORTD_MASK;

    // Set GPIO
    PORTD->PCR[DHT_PIN] &= ~PORT_PCR_MUX_MASK;
    PORTD->PCR[DHT_PIN] |= PORT_PCR_MUX(1);

    // Set as output
    GPIOD->PDDR |= 1 << DHT_PIN;

    // Set off DHT
    GPIOD->PCOR |= 1 << DHT_PIN;

    // Create buzzer task
    xTaskCreate(DHTTask, "DHT", configMINIMAL_STACK_SIZE + 100, NULL, 2, NULL);
}

